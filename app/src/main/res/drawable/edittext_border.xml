<?xml version="1.0" encoding="utf-8"?>
<shape xmlns:android="http://schemas.android.com/apk/res/android"
    android:shape="rectangle">

    <!-- 背景色：白色 -->
    <solid android:color="@color/white" />

    <!-- 边框：橙色，宽度 3dp -->
    <stroke
        android:width="3dp"
        android:color="#FFA500" />

    <!-- 圆角半径 -->
    <corners android:radius="3dp" />

</shape>